{
  "name": "@dss-feeds/x-feed",
  "version": "0.0.0",
  "private": true,
  "description": "Cache-first X post feed contracts with official API, RSS, and fallback sources.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "admin.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./source/x-api": {
      "types": "./dist/source/x-api.d.ts",
      "import": "./dist/source/x-api.js",
      "default": "./dist/source/x-api.js"
    },
    "./source/rss": {
      "types": "./dist/source/rss.d.ts",
      "import": "./dist/source/rss.js",
      "default": "./dist/source/rss.js"
    },
    "./source/fallback": {
      "types": "./dist/source/fallback.d.ts",
      "import": "./dist/source/fallback.js",
      "default": "./dist/source/fallback.js"
    },
    "./package.json": "./package.json",
    "./payload": {
      "types": "./dist/payload/index.d.ts",
      "import": "./dist/payload/index.js",
      "default": "./dist/payload/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./admin.css": "./admin.css"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "payload": ">=3.85.0 <4",
    "react": ">=18.3.0 <20"
  },
  "devDependencies": {
    "payload": "3.85.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "sideEffects": [
    "./admin.css"
  ]
}
