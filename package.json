{
  "name": "dss-feeds",
  "version": "0.0.0",
  "private": true,
  "description": "Cache-first social feed packages with neutral UI and Payload CMS integration.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
