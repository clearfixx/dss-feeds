    "test": "vitest run",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "22.19.9",
    "eslint": "^9.16.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9"
  }
}
